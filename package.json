{
  "name": "hackathon-sokuseki-team1-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply hackathon-sokuseki-team1-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply hackathon-sokuseki-team1-db --remote",
    "test": "node --test --test-isolation=none"
  },
  "devDependencies": {
    "wrangler": "^4.8.0"
  }
}
